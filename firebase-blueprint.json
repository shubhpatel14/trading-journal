            "id": { "type": "string" },
            "date": { "type": "string" },
            "asset": { "type": "string" },
            "bias": { "type": "string" },
            "fourHour": {
              "type": "object",
              "properties": {
                "text": { "type": "string" },
                "bias": { "type": "string" },
                "imageUrl": { "type": "string" }
              }
            },
            "oneHour": {
              "type": "object",
              "properties": {
                "text": { "type": "string" },
                "bias": { "type": "string" },
                "imageUrl": { "type": "string" }
              }
            },
            "fifteenMin": {
              "type": "object",
              "properties": {
                "text": { "type": "string" },
                "bias": { "type": "string" },
                "imageUrl": { "type": "string" }
              }
            },
            "fiveMin": {
              "type": "object",
              "properties": {
                "text": { "type": "string" },
                "bias": { "type": "string" },
                "imageUrl": { "type": "string" }
              }
            },
            "macroNotes": { "type": "string" },
            "triggers": { "type": "string" },
            "status": { "type": "string" },
            "createdAt": { "type": "string" }
          }
        }
